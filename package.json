{
  "name": "bytestream",
  "version": "1.0.0",
  "description": "ByteStream — LeetCode-meets-TikTok full-stack platform",
  "private": true,
  "scripts": {
    "dev": "concurrently -n BACKEND,FRONTEND -c cyan,magenta \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "install:all": "npm install && npm install --prefix backend && npm install --prefix frontend",
    "db:up": "docker compose -f backend/docker-compose.yml up -d",
    "db:down": "docker compose -f backend/docker-compose.yml down",
    "db:migrate": "npm run db:migrate --prefix backend",
    "db:studio": "npm run db:studio --prefix backend"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.1.0"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0"
  }
}
