generator client {
  provider = "prisma-client"
  output   = "../generated/prisma" 
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int       @id @default(autoincrement()) 
  username        String    @unique
  passwordHash    String 
  email           String    @unique
  createdAt       DateTime  @default(now())
  
  // Back-relations
  videos              Video[]  
  comments            Comment[] // A user can write many comments
  commentLikes        CommentLikes[]
  commentDislikes     CommentDislikes[]
  videoLikes          VideoLikes[]
  videoDislikes       VideoDislikes[]
  followers           Subscription[]      @relation("Followers")
  following           Subscription[]      @relation("Following")
}

model Video {
  id              Int       @id @default(autoincrement()) 
  videoTitle      String
  videoUrl        String?
  createdAt       DateTime  @default(now()) 

  creatorId       Int
  creator         User      @relation(fields: [creatorId], references: [id])
  
  problemId       Int       @unique
  codePane        CodePane  @relation(fields: [problemId], references: [id])

  comments        Comment[] 
  videoLikes      VideoLikes[]
  videoDislikes   VideoDislikes[]
}

model CodePane {
  id                 Int      @id @default(autoincrement())
  problemTitle       String   
  problemDescription String
  testCases          Json     

  video              Video?   
}

model Comment {
  id        Int      @id @default(autoincrement())
  text      String
  createdAt DateTime @default(now()) 

  videoId   Int
  video     Video    @relation(fields: [videoId], references: [id])

  // The User who wrote this comment
  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  commentLikes CommentLikes[]
  commentDislikes CommentDislikes[]
}

model VideoLikes {
  videoId   Int
  video     Video   @relation(fields: [videoId], references: [id])

  userId    Int 
  user      User    @relation(fields: [userId], references: [id])

  @@id([videoId, userId])
}

model VideoDislikes {
  videoId   Int
  video     Video   @relation(fields: [videoId], references: [id])

  userId    Int 
  user      User    @relation(fields: [userId], references: [id])

  @@id([videoId, userId])
}

model CommentLikes {
  commentId   Int
  comment   Comment   @relation(fields: [commentId], references: [id])

  userId    Int 
  user      User    @relation(fields: [userId], references: [id])

  @@id([commentId, userId])
}

model CommentDislikes {
  commentId   Int
  comment   Comment   @relation(fields: [commentId], references: [id])

  userId    Int 
  user      User    @relation(fields: [userId], references: [id])

  @@id([commentId, userId])
}

model Subscription {
  // The person who is doing the subscribing (The Viewer)
  subscriberId Int
  subscriber   User @relation("Following", fields: [subscriberId], references: [id])

  // The person who is being subscribed to (The Creator)
  creatorId    Int
  creator      User @relation("Followers", fields: [creatorId], references: [id])

  createdAt    DateTime @default(now())

  // A user can only subscribe to a specific creator once
  @@id([subscriberId, creatorId])
}